# ─────────────────────────────────────────────────────────────────────────────
# CoffeeManager-OS — config/settings.env.example
# Version-controlled SCHEMA only. Copy to settings.env and fill in real values.
#   cp config/settings.env.example config/settings.env
# settings.env itself is gitignored and must never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather → /newbot → copy the token
TELEGRAM_BOT_TOKEN=
# Get from @userinfobot or @getidsbot after messaging your bot
TELEGRAM_CHAT_ID=

# ── OpenClaw ──────────────────────────────────────────────────────────────────
OPENCLAW_API_KEY=

# ── clawdbot gateway (browser automation) ─────────────────────────────────────
# Gateway is started by: clawdbot gateway (runs on port 18789 by default)
CLAWDBOT_AGENT_NAME=main
CLAWDBOT_TASK_TIMEOUT=300

# ── POS Provider ─────────────────────────────────────────────────────────────
# Options: paysera | robolabs | stub (stub = development fixture data)
POS_PROVIDER=stub
POS_POLL_MINUTES=15

# ── Paysera (only needed if POS_PROVIDER=paysera) ─────────────────────────────
PAYSERA_API_KEY=
PAYSERA_MERCHANT_ID=

# ── RoboLabs (only needed if POS_PROVIDER=robolabs) ───────────────────────────
ROBOLABS_API_KEY=
ROBOLABS_LOCATION_ID=

# Maps POS product IDs to internal SKUs: {"pos_id": "INTERNAL_SKU", ...}
POS_SKU_MAP={}

# ── VMI / Sodra ───────────────────────────────────────────────────────────────
# Company VAT code (LT + 9 digits) — used by OpenClaw for portal login
VMI_VAT_CODE=
VMI_COMPANY_CODE=

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=data/memory.sqlite
WORKSPACE_PATH=data/workspace

# ── Runtime flags ─────────────────────────────────────────────────────────────
# Set to true to run full pipeline without sending any notifications
DRY_RUN=false

# ── API Authentication ────────────────────────────────────────────────────────
# Telegram webhook secret token (must match the secret passed to setWebhook)
TELEGRAM_SECRET_TOKEN=
# Bearer token for /confirm and /dismiss endpoints (generate a strong random token)
API_BEARER_TOKEN=
# Shared secret for /webhook/pos endpoint (optional, leave empty if not needed)
WEBHOOK_POS_SECRET=
# API binding address (127.0.0.1 for localhost only, 0.0.0.0 for all interfaces)
API_HOST=127.0.0.1
# CORS allowed origins (comma-separated, defaults to 127.0.0.1)
CORS_ALLOW_ORIGINS=127.0.0.1
# Dashboard HTTP Basic auth — REQUIRED. The dashboard page embeds API_BEARER_TOKEN
# so it can call /confirm and /dismiss; without these the page (and that token) is
# served to anyone who can reach it. The app fails closed (HTTP 503) if unset.
# If you ever set API_HOST=0.0.0.0, you MUST put the app behind an HTTPS reverse proxy.
DASHBOARD_USER=owner
DASHBOARD_PASSWORD=

# ── Telegram Mini App (barista calendar) ──────────────────────────────────────
# Public HTTPS URL of the /miniapp page, e.g. https://coffee.example.com/miniapp
# Leave BLANK until the domain/tunnel resolves: miniapp_button() returns no button
# and set_menu_button.py refuses to run, so nothing breaks while it's empty.
MINIAPP_URL=
# DEV-ONLY auth bypass for testing the live fetch path on localhost without
# Telegram. Set to a barista name (new throwaway) or an existing barista's numeric
# telegram id. INERT in production: ignored whenever DRY_RUN=false. Leave BLANK.
MINIAPP_DEV_USER=

# ── Feature Flags (for in-development modules) ────────────────────────────────
# Customer sentiment loop (reviews, winback posts): false until module is complete
FEATURE_SENTIMENT_LOOP=false
# Barista HR (level tracking, promotions): false until module is complete
FEATURE_HR_MANAGER=false

# ── Observability ─────────────────────────────────────────────────────────────
# Pydantic Logfire token (from logfire dashboard). Empty = tracing is a silent no-op.
LOGFIRE_TOKEN=
LOGFIRE_ENVIRONMENT=production
# Healthchecks.io ping URL for the daily-audit dead-man's-switch. Empty = no-op.
HEALTHCHECK_AUDIT_URL=
# Monthly i.SAF reminder check (configure in Healthchecks CRON mode: 0 9 12 * * UTC).
HEALTHCHECK_ISAF_URL=

# ── Scheduling bot identity ───────────────────────────────────────────────────
AGENT_NAME=CoffeeBot

# ── Telegram group (supergroup with topics/forum enabled) ─────────────────────
# Add the bot to the group, then forward any group message to @userinfobot
# to get the group ID (it will be negative, e.g. -1001234567890)
TELEGRAM_GROUP_ID=
# For each topic: open it, forward a message to @userinfobot → "Thread ID"
TELEGRAM_ANNOUNCE_THREAD=
TELEGRAM_SCHEDULE_THREAD=
TELEGRAM_TEAMCHAT_THREAD=

# ── Shop location (Open-Meteo weather — Vilnius defaults) ─────────────────────
SHOP_LAT=54.6872
SHOP_LON=25.2797
SHOP_OPEN_HOUR=8
SHOP_CLOSE_HOUR=21

# ── Labor scheduling thresholds ───────────────────────────────────────────────
BARISTA_HOURLY_RATE=9.50
LABOR_TARGET_PCT=0.32
SCHEDULE_PEAK_THRESH=0.80
SCHEDULE_NORMAL_THRESH=0.55
SCHEDULE_LOCK_DAYS=5
SCHEDULE_PEAK_COUNT=3
SCHEDULE_NORMAL_COUNT=2
SCHEDULE_QUIET_COUNT=1

# ── Google Business Profile (customer sentiment loop) ─────────────────────────
# GBP_STUB_MODE=true until Google API approval arrives; no real API calls made.
GBP_STUB_MODE=true
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=
GBP_ACCOUNT_ID=
GBP_LOCATION_ID=
GBP_ALERT_STARS=2
GBP_TREND_DROP=0.3
GBP_REFRESH_TOKEN=

# ── Shop identity (used in review replies and winback posts) ──────────────────
SHOP_NAME=your shop name
SHOP_WEBSITE_URL=https://yoursite.lt

# ── HR / wage settings ────────────────────────────────────────────────────────
# Standard shift length used for swap cost calculations and roster cost reports
BARISTA_SHIFT_HOURS=8
